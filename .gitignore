# ======================================================================
# AlgoVoyage .gitignore
# ======================================================================
# 结构：IDE → Python → 数据文件 → 嵌入式工程
# ======================================================================


# ----------------------------------------------------------------------
# §1  IDE & 操作系统
# ----------------------------------------------------------------------
.idea/
.vscode/
.DS_Store
Thumbs.db


# ----------------------------------------------------------------------
# §2  Python 运行环境
# ----------------------------------------------------------------------
.venv/
venv/
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/


# ----------------------------------------------------------------------
# §3  科研数据集（禁止入库，体积过大）
# ----------------------------------------------------------------------
*.csv
*.xlsx
*.xls
*.mat
*.log


# ----------------------------------------------------------------------
# §4  Keil MDK / STM32 嵌入式工程
# ----------------------------------------------------------------------

# 编译中间产物
*.o
*.d
*.crf
*.dep
*.lnp
*.sct
*.lst
*.iex
*.bak

# 编译报告与日志
*.htm
*.map
*.build_log.htm

# 烧录与最终二进制输出
*.axf
*.hex
*.bin

# Keil 本地 UI 配置（因人而异，不共享）
*.uvguix.*
*.uvoptx

# Keil 自动生成的输出目录（** 匹配任意深度路径）
**/MDK-ARM/fly/
**/MDK-ARM/Objects/
**/MDK-ARM/Listings/
**/MDK-ARM/DebugConfig/
